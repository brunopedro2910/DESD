# Gather local Docker configuration
DJANGO_SECRET_KEY=replace-with-a-long-random-value-before-public-deployment
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

DB_NAME=gather_db
DB_USER=gather_user
DB_PASSWORD=gather_dev_password
CACHE_URL=redis://redis:6379/1

RUN_MIGRATIONS=true
SEED_DEMO_DATA=true
USE_REDIS_CACHE=true

# Enable these only when the application is served through HTTPS.
DJANGO_SECURE_COOKIES=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0
